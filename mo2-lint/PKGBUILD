pkgname=mo2-lint
pkgver=7.0.0rc6
pkgrel=1
_tag=7.0.0-rc6
pkgdesc="Mod Organizer 2 Linux Installer"
arch=(
  'x86_64'
)
url="https://github.com/Furglitch/modorganizer2-linux-installer"
license=(
  'GPL-3.0-only'
)
depends=(
  'procps-ng'
  'xdg-utils'
)
makedepends=(
  'curl'
  'make'
  'unzip'
  'uv'
  'wget'
  'wine'
  'wine-mono'
)
optdepends=(
  'steam: Steam games support'
  'protontricks: external Protontricks support'
  'winetricks: external Winetricks support'
)
source=("${pkgname}-${_tag}.tar.gz::${url}/archive/refs/tags/${_tag}.tar.gz")
sha256sums=(
  '96145b04c4dd2328060998fc92768feda56e532508917922ddb6705c4512114b'
)

build() {
  cd "modorganizer2-linux-installer-${pkgver/rc/-rc}"

  export HOME="${srcdir}/home"
  export UV_CACHE_DIR="${srcdir}/uv-cache"
  export WINEPREFIX="${srcdir}/wine-py"
  export WINEARCH=win64

  make clean
  make mo2-lint
}

package() {
  cd "modorganizer2-linux-installer-${pkgver/rc/-rc}"

  install -Dm755 "dist/${pkgname}" \
    "${pkgdir}/usr/bin/${pkgname}"
}
